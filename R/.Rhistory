prop.table(table(df$number_of_times90days_late, df$default), 1)
ggplot(df, aes(number_of_times90days_late, fill = default)) +
geom_bar(position = "fill") +
coord_cartesian(xlim = c(0, 10)) +
xlab("Number of Times 90 Days Late") +
ylab("Proportion") +
ggtitle("Default Rate by Late Payments")
library(tidyverse)
df <- read_csv("credit_scoring_clean.csv")
######### 2. Prepare target variable #########
# Convert default into a factor
df$default <- factor(df$default, levels = c("No", "Yes"))
# Check target distribution
table(df$default)
prop.table(table(df$default))
######### 3. Build the logistic regression model #########
# Logistic regression is commonly used in credit scoring
# The model tries to explain default using all other variables
model <- glm(default ~ ., data = df, family = binomial)
######### 4. Show model results #########
summary(model)
library(tidyverse)
######### 1. Load cleaned data #########
df <- read_csv("credit_scoring_clean.csv")
# Check the data
head(df)
str(df)
summary(df)
######### 2. Prepare the target variable #########
# Make sure default is a factor
df$default <- factor(df$default, levels = c("No", "Yes"))
# Check target distribution
table(df$default)
prop.table(table(df$default))
######### 3. Split data into train and test #########
set.seed(123)
# Create random sample for train set
train_index <- sample(1:nrow(df), 0.7 * nrow(df))
train_data <- df[train_index, ]
test_data  <- df[-train_index, ]
# Check dimensions
dim(train_data)
dim(test_data)
######### 4. Build the logistic regression model #########
# Logistic regression is widely used in credit scoring
model <- glm(default ~ ., data = train_data, family = binomial)
######### 5. Show model results #########
summary(model)
######### 6. Predict probabilities on test set #########
test_data$predicted_probability <- predict(model, newdata = test_data, type = "response")
# Check predicted probabilities
head(test_data$predicted_probability)
summary(test_data$predicted_probability)
######### 7. Create predicted classes #########
# Threshold = 0.5
test_data$predicted_class <- ifelse(test_data$predicted_probability > 0.5, "Yes", "No")
test_data$predicted_class <- factor(test_data$predicted_class, levels = c("No", "Yes"))
# Compare predicted and actual values
table(Predicted = test_data$predicted_class, Actual = test_data$default)
######### 8. Accuracy #########
accuracy <- mean(test_data$predicted_class == test_data$default)
accuracy
######### 9. Confusion matrix measures #########
conf_matrix <- table(Predicted = test_data$predicted_class, Actual = test_data$default)
conf_matrix
# Extract values
TN <- conf_matrix["No", "No"]
TP <- conf_matrix["Yes", "Yes"]
FN <- conf_matrix["No", "Yes"]
FP <- conf_matrix["Yes", "No"]
# Compute basic metrics
precision <- TP / (TP + FP)
recall <- TP / (TP + FN)
specificity <- TN / (TN + FP)
precision
recall
specificity
######### 10. Variable importance from coefficients #########
# Extract coefficients
importance <- data.frame(
variable = names(coef(model)),
coefficient = coef(model)
)
# Absolute value of coefficients
importance$abs_coefficient <- abs(importance$coefficient)
# Sort variables by importance
importance <- importance[order(-importance$abs_coefficient), ]
# Show top variables
head(importance, 10)
######### 11. Plot top 5 variables #########
# Remove intercept
importance_no_intercept <- importance[importance$variable != "(Intercept)", ]
# Keep top 5
top5 <- head(importance_no_intercept, 5)
ggplot(top5, aes(x = reorder(variable, abs_coefficient), y = abs_coefficient)) +
geom_bar(stat = "identity") +
coord_flip() +
xlab("Variables") +
ylab("Absolute Coefficient") +
ggtitle("Top 5 Variables for Predicting Default")
######### 12. Predict probability for all clients #########
df$predicted_probability <- predict(model, newdata = df, type = "response")
head(df$predicted_probability)
summary(df$predicted_probability)
######### 13. Rank clients by risk #########
df_risk <- df %>% arrange(desc(predicted_probability))
# Show top risky clients
head(df_risk, 10)
######### 14. Create simple risk groups #########
df$risk_group <- cut(
df$predicted_probability,
breaks = c(0, 0.2, 0.5, 1),
labels = c("Low", "Medium", "High"),
include.lowest = TRUE
)
table(df$risk_group)
prop.table(table(df$risk_group))
######### 15. Plot risk group distribution #########
ggplot(df, aes(risk_group)) +
geom_bar() +
xlab("Risk Group") +
ylab("Count") +
ggtitle("Distribution of Risk Groups")
######### 16. Average probability by risk group #########
aggregate(predicted_probability ~ risk_group, data = df, mean)
######### 17. Save results #########
write.csv(test_data, "credit_scoring_test_predictions.csv", row.names = FALSE)
write.csv(df, "credit_scoring_all_predictions.csv", row.names = FALSE)
write.csv(importance, "variable_importance.csv", row.names = FALSE)
library(tidyverse)
######### 1. Load cleaned data #########
df <- read_csv("credit_scoring_clean.csv")
# Check the data
head(df)
str(df)
summary(df)
######### 2. Prepare the target variable #########
# Make sure default is a factor
df$default <- factor(df$default, levels = c("No", "Yes"))
# Check target distribution
table(df$default)
prop.table(table(df$default))
######### 3. Split data into train and test #########
set.seed(123)
# Create random sample for train set
train_index <- sample(1:nrow(df), 0.7 * nrow(df))
train_data <- df[train_index, ]
test_data  <- df[-train_index, ]
# Check dimensions
dim(train_data)
dim(test_data)
######### 4. Build the logistic regression model #########
model <- glm(default ~ ., data = train_data, family = binomial)
######### 5. Show model results #########
summary(model)
######### 6. Predict probabilities on test set #########
test_data$predicted_probability <- predict(model, newdata = test_data, type = "response")
head(test_data$predicted_probability)
summary(test_data$predicted_probability)
######### 7. Create predicted classes #########
# Threshold = 0.5
test_data$predicted_class <- ifelse(test_data$predicted_probability > 0.5, "Yes", "No")
test_data$predicted_class <- factor(test_data$predicted_class, levels = c("No", "Yes"))
table(Predicted = test_data$predicted_class, Actual = test_data$default)
######### 8. Accuracy #########
accuracy <- mean(test_data$predicted_class == test_data$default)
accuracy
######### 9. Confusion matrix measures #########
conf_matrix <- table(Predicted = test_data$predicted_class, Actual = test_data$default)
conf_matrix
TN <- conf_matrix["No", "No"]
TP <- conf_matrix["Yes", "Yes"]
FN <- conf_matrix["No", "Yes"]
FP <- conf_matrix["Yes", "No"]
precision <- TP / (TP + FP)
recall <- TP / (TP + FN)
specificity <- TN / (TN + FP)
precision
recall
specificity
######### 10. Threshold loop #########
thresholds <- seq(0.01, 0.50, by = 0.01)
results <- data.frame()
for (t in thresholds) {
pred <- ifelse(test_data$predicted_probability > t, "Yes", "No")
pred <- factor(pred, levels = c("No", "Yes"))
cm <- table(pred, test_data$default)
TN <- cm["No","No"]
TP <- cm["Yes","Yes"]
FN <- cm["No","Yes"]
FP <- cm["Yes","No"]
precision_t <- TP / (TP + FP)
recall_t <- TP / (TP + FN)
accuracy_t <- (TP + TN) / sum(cm)
results <- rbind(results,
data.frame(
threshold = t,
precision = precision_t,
recall = recall_t,
accuracy = accuracy_t
))
}
results
######### 11. Variable importance from coefficients #########
importance <- data.frame(
variable = names(coef(model)),
coefficient = coef(model)
)
importance$abs_coefficient <- abs(importance$coefficient)
importance <- importance[order(-importance$abs_coefficient), ]
head(importance, 10)
######### 12. Plot top 5 variables #########
importance_no_intercept <- importance[importance$variable != "(Intercept)", ]
top5 <- head(importance_no_intercept, 5)
ggplot(top5, aes(x = reorder(variable, abs_coefficient), y = abs_coefficient)) +
geom_bar(stat = "identity") +
coord_flip() +
xlab("Variables") +
ylab("Absolute Coefficient") +
ggtitle("Top 5 Variables for Predicting Default")
######### 13. Predict probability for all clients #########
df$predicted_probability <- predict(model, newdata = df, type = "response")
head(df$predicted_probability)
summary(df$predicted_probability)
######### 14. Rank clients by risk #########
df_risk <- df %>% arrange(desc(predicted_probability))
head(df_risk, 10)
######### 15. Create simple risk groups #########
df$risk_group <- cut(
df$predicted_probability,
breaks = c(0, 0.2, 0.5, 1),
labels = c("Low", "Medium", "High"),
include.lowest = TRUE
)
table(df$risk_group)
prop.table(table(df$risk_group))
######### 16. Plot risk group distribution #########
ggplot(df, aes(risk_group)) +
geom_bar() +
xlab("Risk Group") +
ylab("Count") +
ggtitle("Distribution of Risk Groups")
######### 17. Average probability by risk group #########
aggregate(predicted_probability ~ risk_group, data = df, mean)
######### 18. Save results #########
write.csv(test_data, "credit_scoring_test_predictions.csv", row.names = FALSE)
write.csv(df, "credit_scoring_all_predictions.csv", row.names = FALSE)
write.csv(importance, "variable_importance.csv", row.names = FALSE)
write.csv(results, "threshold_results.csv", row.names = FALSE)
